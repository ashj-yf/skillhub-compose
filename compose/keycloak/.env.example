# ================================
# Keycloak 配置
# ================================

# 数据库连接（复用 PostgreSQL 实例，使用专用用户）
POSTGRES_HOST=172.16.0.1
POSTGRES_PORT=5432
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=keycloak_demo
KEYCLOAK_DB=keycloak

# Keycloak 端口
KEYCLOAK_PORT=8180

# Keycloak 管理员
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=ChangeMe!2026

# 对外访问地址（start-dev 模式下自动处理，生产模式需设置 KC_HOSTNAME）
# KC_HOSTNAME=http://172.16.0.1:8180
