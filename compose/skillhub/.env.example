# ================================
# 镜像版本配置
# ================================
# `latest` 跟踪最新稳定版，生产环境建议锁定版本如 `v0.1.0`
# `edge` 仅在需要 main 分支最新构建时使用
SKILLHUB_VERSION=latest
SKILLHUB_SERVER_IMAGE=ghcr.io/iflytek/skillhub-server
SKILLHUB_WEB_IMAGE=ghcr.io/iflytek/skillhub-web
SKILLHUB_SCANNER_IMAGE=ghcr.io/iflytek/skillhub-scanner
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine

# ================================
# 宿主机 IP 配置
# ================================
# 修改为你的宿主机内网 IP
HOST_IP=172.16.0.1

# ================================
# 端口配置
# ================================
# 基础设施服务端口
POSTGRES_BIND_ADDRESS=0.0.0.0
POSTGRES_PORT=5432
REDIS_BIND_ADDRESS=0.0.0.0
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
KEYCLOAK_PORT=8180

# SkillHub 服务端口
API_PORT=8081
WEB_PORT=8082
SCANNER_PORT=8083

# 会话安全配置
SESSION_COOKIE_SECURE=false

# ================================
# 服务地址配置
# ================================
# 数据库地址
POSTGRES_HOST=${HOST_IP}
POSTGRES_FULL_ADDRESS=${HOST_IP}:${POSTGRES_PORT}

# Redis 地址
REDIS_HOST=${HOST_IP}
REDIS_FULL_ADDRESS=${HOST_IP}:${REDIS_PORT}

# MinIO 地址
MINIO_ENDPOINT=${HOST_IP}:${MINIO_PORT}
MINIO_PUBLIC_URL=http://${MINIO_ENDPOINT}
MINIO_CONSOLE_URL=http://${HOST_IP}:${MINIO_CONSOLE_PORT}

# SkillHub 服务地址
API_FULL_ADDRESS=${HOST_IP}:${API_PORT}
WEB_FULL_ADDRESS=${HOST_IP}:${WEB_PORT}
SCANNER_FULL_ADDRESS=${HOST_IP}:${SCANNER_PORT}

# 公共访问地址（浏览器/CLI 可见入口，无尾斜杠）
SKILLHUB_PUBLIC_BASE_URL=http://${HOST_IP}
SKILLHUB_WEB_API_BASE_URL=
SKILLHUB_API_UPSTREAM=http://server:8080

# MinIO S3 配置
SKILLHUB_STORAGE_S3_ENDPOINT=http://${MINIO_ENDPOINT}
SKILLHUB_STORAGE_S3_PUBLIC_ENDPOINT=http://${MINIO_ENDPOINT}

# Scanner 地址
SKILLHUB_SECURITY_SCANNER_URL=http://${SCANNER_FULL_ADDRESS}

# 设备授权验证地址（可选，默认 ${SKILLHUB_PUBLIC_BASE_URL}/device）
DEVICE_AUTH_VERIFICATION_URI=

# Keycloak 地址
KEYCLOAK_HOSTNAME=${HOST_IP}:${KEYCLOAK_PORT}
KEYCLOAK_URL=http://${KEYCLOAK_HOSTNAME}

# ================================
# 数据库配置
# ================================
POSTGRES_DB=skillhub
POSTGRES_USER=skillhub
POSTGRES_PASSWORD=skillhub_demo

# ================================
# MinIO S3 配置
# ================================
SKILLHUB_STORAGE_S3_BUCKET=skillhub
SKILLHUB_STORAGE_S3_ACCESS_KEY=minioadmin
SKILLHUB_STORAGE_S3_SECRET_KEY=minioadmin
SKILLHUB_STORAGE_S3_REGION=us-east-1
SKILLHUB_STORAGE_S3_FORCE_PATH_STYLE=true
# 阿里云 OSS 拒绝 aws-chunked 编码，使用阿里云 OSS 时设为 true
SKILLHUB_STORAGE_S3_DISABLE_CHUNKED_ENCODING=false
SKILLHUB_STORAGE_S3_AUTO_CREATE_BUCKET=true
SKILLHUB_STORAGE_S3_PRESIGN_EXPIRY=PT10M

# ================================
# 管理员配置
# ================================
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_USER_ID=docker-admin
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!2026
BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin
BOOTSTRAP_ADMIN_EMAIL=admin@skillhub.local

# ================================
# OAuth2 登录配置（可选）
# ================================
# 【重要】未配置时请保持注释，避免 Spring Boot OAuth2 验证失败导致应用无法启动
# GitHub OAuth
# OAUTH2_GITHUB_CLIENT_ID=
# OAUTH2_GITHUB_CLIENT_SECRET=

# GitLab OAuth（自托管 GitLab 需修改 OAUTH2_GITLAB_BASE_URI）
# OAUTH2_GITLAB_CLIENT_ID=
# OAUTH2_GITLAB_CLIENT_SECRET=
# OAUTH2_GITLAB_BASE_URI=https://gitlab.com
# OAUTH2_GITLAB_DISPLAY_NAME=GitLab

# OIDC 登录（如 Keycloak、Okta、Azure AD）
# 将变量名中的 OIDC 替换为你的 registration id（大写）
# registration id 会成为 identity_binding.provider_code，请保持稳定
# 【可选】部署 Keycloak 后在管理控制台创建 Client，将 Client ID 和 Secret 填入下方
# 未填写时 SkillHub 不会启用 OIDC 登录
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_OIDC_CLIENT_ID=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_OIDC_CLIENT_SECRET=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_OIDC_PROVIDER=oidc
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_OIDC_AUTHORIZATION_GRANT_TYPE=authorization_code
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_OIDC_REDIRECT_URI={baseUrl}/login/oauth2/code/{registrationId}
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_OIDC_SCOPE=openid,profile,email
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_OIDC_CLIENT_NAME=Keycloak
# 部署 Keycloak 后取消注释并填入实际地址：
# SPRING_SECURITY_OAUTH2_CLIENT_PROVIDER_OIDC_ISSUER_URI=http://<HOST_IP>:8180/realms/skillhub

# ================================
# SMTP 邮件配置（可选，用于密码重置验证邮件）
# ================================
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_SSL_ENABLE=false
SPRING_MAIL_PROPERTIES_MAIL_SMTP_SSL_TRUST=
SKILLHUB_AUTH_PASSWORD_RESET_CODE_EXPIRY=PT10M
SKILLHUB_AUTH_PASSWORD_RESET_FROM_ADDRESS=noreply@example.com
SKILLHUB_AUTH_PASSWORD_RESET_FROM_NAME=SkillHub

# ================================
# Keycloak 配置（OIDC Provider，用于 LDAP 等外部认证桥接）
# ================================
KEYCLOAK_DB=keycloak
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=ChangeMe!2026

# Keycloak Realm 名称
KEYCLOAK_REALM=skillhub

# SkillHub 在 Keycloak 中创建的 OIDC Client 配置
# 部署 Keycloak 后在管理控制台创建 Client，将 Client ID 和 Secret 填入上方 OIDC 配置块
# 参考 issuer URI 格式：http://<HOST_IP>:8180/realms/<KEYCLOAK_REALM>
# OAUTH2_OIDC_CLIENT_ID=
# OAUTH2_OIDC_CLIENT_SECRET=
