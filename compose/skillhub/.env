# SkillHub 应用服务配置

# ================================
# 全局配置
# ================================
SKILLHUB_VERSION=latest
SKILLHUB_PUBLIC_BASE_URL=http://localhost

# ================================
# Server 配置
# ================================
SKILLHUB_SERVER_IMAGE=ghcr.io/iflytek/skillhub-server
API_BIND_ADDRESS=0.0.0.0
API_PORT=8081

# Session 安全
SESSION_COOKIE_SECURE=false

# 设备认证 (可选)
DEVICE_AUTH_VERIFICATION_URI=

# ================================
# 存储配置
# ================================
# Provider: s3 (支持 S3 兼容存储，如 MinIO/RustFS)
SKILLHUB_STORAGE_PROVIDER=s3

# S3 存储配置 - 使用 RustFS 作为后端 (RustFS 独立运行)
SKILLHUB_STORAGE_S3_ENDPOINT=http://host.docker.internal:8000
SKILLHUB_STORAGE_S3_PUBLIC_ENDPOINT=http://host.docker.internal:8000
SKILLHUB_STORAGE_S3_BUCKET=skillhub
SKILLHUB_STORAGE_S3_ACCESS_KEY=
SKILLHUB_STORAGE_S3_SECRET_KEY=
SKILLHUB_STORAGE_S3_REGION=us-east-1
SKILLHUB_STORAGE_S3_FORCE_PATH_STYLE=true
SKILLHUB_STORAGE_S3_AUTO_CREATE_BUCKET=true
SKILLHUB_STORAGE_S3_PRESIGN_EXPIRY=PT10M

# 安全扫描
SKILLHUB_SECURITY_SCANNER_ENABLED=true
SKILLHUB_SECURITY_SCANNER_URL=http://skill-scanner:8083
SKILLHUB_SECURITY_SCANNER_MODE=upload

# 初始管理员
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_USER_ID=docker-admin
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!2026
BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin
BOOTSTRAP_ADMIN_EMAIL=admin@skillhub.local

# OAuth2 GitHub (可选)
OAUTH2_GITHUB_CLIENT_ID=
OAUTH2_GITHUB_CLIENT_SECRET=

# ================================
# Web 配置
# ================================
SKILLHUB_WEB_IMAGE=ghcr.io/iflytek/skillhub-web
WEB_BIND_ADDRESS=0.0.0.0
WEB_PORT=8082
SKILLHUB_API_UPSTREAM=http://server:8081
SKILLHUB_WEB_API_BASE_URL=

# ================================
# Scanner 配置
# ================================
SKILLHUB_SCANNER_IMAGE=ghcr.io/iflytek/skillhub-scanner
SCANNER_BIND_ADDRESS=0.0.0.0
SCANNER_PORT=8083

# LLM 设置
SKILL_SCANNER_LLM_API_KEY=
SKILL_SCANNER_LLM_BASE_URL=
SKILL_SCANNER_LLM_MODEL=

# ================================
# 依赖服务连接配置
# ================================
# 连接方式说明:
# 1. 容器网络模式：使用容器名，需要所有容器在同一网络
#    POSTGRES_HOST=postgres
#    REDIS_HOST=redis
#
# 2. 宿主机模式：使用宿主机 IP，postgres/redis 端口暴露到宿主机
#    POSTGRES_HOST=192.168.1.100
#    REDIS_HOST=192.168.1.100

# 默认使用容器名
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=skillhub
POSTGRES_USER=skillhub
POSTGRES_PASSWORD=skillhub_demo

REDIS_HOST=redis
REDIS_PORT=6379
