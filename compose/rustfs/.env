# RustFS 文件服务配置

# RustFS 镜像
RUSTFS_IMAGE=ghcr.io/rustfs/rustfs:latest

# 网络绑定 (0.0.0.0 允许外部访问，127.0.0.1 仅本地)
RUSTFS_BIND_ADDRESS=0.0.0.0
RUSTFS_PORT=8000

# 服务配置
RUSTFS_WORKERS=4
RUSTFS_MAX_UPLOAD_SIZE=104857600
RUSTFS_ALLOWED_EXTENSIONS=
RUSTFS_STORAGE_PATH=/data

# 公共访问 URL
RUSTFS_PUBLIC_URL=http://localhost:8000

# 认证 Token (可选)
RUSTFS_AUTH_TOKEN=
