# RustFS 文件服务配置

# RustFS 镜像
RUSTFS_IMAGE=ghcr.io/rustfs/rustfs:latest

# 网络绑定
RUSTFS_BIND_ADDRESS=127.0.0.1
RUSTFS_PORT=8000

# 服务配置
RUSTFS_WORKERS=4
RUSTFS_MAX_UPLOAD_SIZE=104857600
RUSTFS_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,zip

# 存储路径 (容器内)
RUSTFS_STORAGE_PATH=/data

# 公共访问 URL
RUSTFS_PUBLIC_URL=http://localhost:8000

# 认证 Token (可选)
RUSTFS_AUTH_TOKEN=
